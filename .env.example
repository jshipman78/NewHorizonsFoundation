# New Horizons Foundation - Environment Variables
# Copy this file to .env.local and fill in the values

# Site URL (used for sitemap and canonical URLs)
NEXT_PUBLIC_SITE_URL=https://www.newhorizonsfoundation.org

# Formspree - Contact Form
# Get your form ID from https://formspree.io
NEXT_PUBLIC_FORMSPREE_ENDPOINT=https://formspree.io/f/YOUR_FORM_ID

# Google Analytics (optional)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Donorbox (optional - for donation integration)
# NEXT_PUBLIC_DONORBOX_CAMPAIGN_ID=your_campaign_id
